{
  "name": "chatplayground-relay",
  "version": "0.1.0",
  "description": "OpenAI-compatible Cloudflare Worker relay for chatplayground.ai (BYOK, stateless)",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy --minify",
    "typecheck": "tsc --noEmit",
    "format": "biome check --write src/",
    "lint": "biome lint src/",
    "check": "biome check src/",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "cloudflare",
    "worker",
    "chatplayground",
    "openai",
    "relay"
  ],
  "license": "MIT",
  "dependencies": {
    "hono": "^4.6.14"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.2",
    "@cloudflare/vitest-pool-workers": "^0.5.40",
    "@cloudflare/workers-types": "^4.20250701.0",
    "typescript": "^5.9.3",
    "vitest": "~2.1.9",
    "wrangler": "^4.107.0"
  }
}
